<UserControl x:Class="FpdSimViewer.Views.Tabs.DataPathTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border Style="{StaticResource PanelBorderStyle}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="Data Path" Style="{StaticResource SectionTitleStyle}" />

            <TextBlock Grid.Row="1"
                       Text="{Binding PathSummary}"
                       Style="{StaticResource CaptionTextStyle}"
                       Margin="0,0,0,10" />

            <ItemsControl Grid.Row="2" ItemsSource="{Binding Stages}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" Columns="5" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,8,8"
                                Padding="10"
                                Background="{Binding Fill}"
                                CornerRadius="10">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           Foreground="White" />
                                <TextBlock Text="{Binding Summary}"
                                           Margin="0,8,0,0"
                                           Foreground="White"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Detail}"
                                           Margin="0,6,0,0"
                                           Foreground="#F5FFFB"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Grid.Row="3"
                       Text="{Binding LineBufferSummary}"
                       FontWeight="SemiBold"
                       Margin="0,4,0,8" />

            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ItemsControl ItemsSource="{Binding BufferBanks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,8,8"
                                    Padding="12"
                                    Background="#FFF5F7FA"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding Name}"
                                                   FontWeight="SemiBold" />
                                        <Border DockPanel.Dock="Right"
                                                Background="{Binding Fill}"
                                                CornerRadius="10"
                                                Padding="8,2">
                                            <TextBlock Text="{Binding Role}"
                                                       Foreground="White"
                                                       FontSize="11"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </DockPanel>
                                    <ProgressBar Margin="0,10,0,0"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Height="16"
                                                 Value="{Binding FillPercent}" />
                                    <TextBlock Text="{Binding Summary}"
                                               Margin="0,8,0,0"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Detail}"
                                               Margin="0,4,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <Border Margin="0,8,8,0"
                            Padding="12"
                            Background="#FFF5F7FA"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="CSI-2 Packet Summary"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="{Binding CsiPacketSummary}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding CsiIntegritySummary}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource CaptionTextStyle}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Text="FS/Line/FE packet counts are synthesized from current row progress until dedicated CSI-2 models arrive." />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Margin="0,8,0,0"
                            Padding="12"
                            Background="#FFF5F7FA"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="Pixel Preview"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <Border Margin="0,4,0,0"
                                    Background="#FF102A43"
                                    CornerRadius="6"
                                    Padding="4">
                                <Image Source="{Binding PixelPreview}"
                                       Height="46"
                                       Stretch="Fill" />
                            </Border>
                            <TextBlock Text="{Binding PixelPreviewSummary}"
                                       Margin="0,8,0,0"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding PixelStatsSummary}"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource CaptionTextStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
