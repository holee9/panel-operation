<UserControl x:Class="FpdSimViewer.Views.Controls.RegisterEditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border Style="{StaticResource PanelBorderStyle}">
        <Expander IsExpanded="True" Header="Register Editor">
            <DataGrid ItemsSource="{Binding Registers}">
                <DataGrid.Resources>
                    <Style TargetType="DataGridCell">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                <Setter Property="Background" Value="{StaticResource Brush.PanelAlt}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Addr" Binding="{Binding AddressHex}" IsReadOnly="True" Width="70" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="120" />
                    <DataGridTextColumn Header="Value" Binding="{Binding ValueHex, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                    <DataGridTextColumn Header="Access" Binding="{Binding Access}" IsReadOnly="True" Width="60" />
                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" IsReadOnly="True" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Expander>
    </Border>
</UserControl>
