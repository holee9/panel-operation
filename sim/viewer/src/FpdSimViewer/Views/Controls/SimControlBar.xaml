<UserControl x:Class="FpdSimViewer.Views.Controls.SimControlBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border Style="{StaticResource PanelBorderStyle}" Margin="6,6,6,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Combo" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="0,0,4,0" />
                <ComboBox ItemsSource="{Binding ComboOptions}" SelectedItem="{Binding SelectedCombo}" DisplayMemberPath="Label" />
                <TextBlock Text="Mode" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="12,0,4,0" />
                <ComboBox ItemsSource="{Binding ModeOptions}" SelectedItem="{Binding SelectedMode}" DisplayMemberPath="Label" />
                <Button Content="Reset" Command="{Binding ResetCommand}" />
                <Button Content="Step" Command="{Binding StepCommand}" />
                <Button Content="{Binding PlayPauseLabel}" Command="{Binding TogglePlayCommand}" Width="88" />
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Speed" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="0,0,8,0" />
                <Slider Width="180" Minimum="1" Maximum="120" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding Speed}" />
                <TextBlock Text="{Binding Speed}" Width="36" VerticalAlignment="Center" TextAlignment="Right" Margin="4,0,0,0" />
            </StackPanel>

            <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                <TextBlock Text="Power" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="0,0,4,0" />
                <ComboBox ItemsSource="{Binding PowerTargetModes}" SelectedItem="{Binding PowerTargetMode}" Width="72" />
                <CheckBox Content="VGL Stable" IsChecked="{Binding VglStable}" />
                <CheckBox Content="VGH Stable" IsChecked="{Binding VghStable}" />

                <TextBlock Text="X-ray" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="18,0,4,0" />
                <CheckBox Content="Ready" IsChecked="{Binding XrayReady}" />
                <CheckBox Content="Prep" IsChecked="{Binding XrayPrepRequest}" />
                <CheckBox Content="On" IsChecked="{Binding XrayOn}" />
                <CheckBox Content="Off" IsChecked="{Binding XrayOff}" />

                <TextBlock Text="Faults" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="18,0,4,0" />
                <CheckBox Content="VGH Over" IsChecked="{Binding FaultVghOver}" />
                <CheckBox Content="VGH Under" IsChecked="{Binding FaultVghUnder}" />
                <CheckBox Content="Temp Over" IsChecked="{Binding FaultTempOver}" />
                <CheckBox Content="PLL Unlocked" IsChecked="{Binding FaultPllUnlocked}" />
                <CheckBox Content="HW Emergency" IsChecked="{Binding HardwareEmergencyActive}" />
            </WrapPanel>
        </Grid>
    </Border>
</UserControl>
