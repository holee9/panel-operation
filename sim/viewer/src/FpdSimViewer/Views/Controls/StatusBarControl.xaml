<UserControl x:Class="FpdSimViewer.Views.Controls.StatusBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border Style="{StaticResource PanelBorderStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                <TextBlock Text="State" Style="{StaticResource CaptionTextStyle}" Margin="0,0,6,0" VerticalAlignment="Center" />
                <Border Padding="10,4"
                        Background="{Binding CurrentSnapshot.FsmState, Converter={StaticResource FsmStateToColorConverter}}"
                        CornerRadius="8">
                    <TextBlock Text="{Binding FsmStateName}" Foreground="White" FontWeight="SemiBold" />
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                <TextBlock Text="Row" Style="{StaticResource CaptionTextStyle}" Margin="0,0,6,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding CurrentRow}" FontWeight="SemiBold" />
                <TextBlock Text="/" Margin="4,0" />
                <TextBlock Text="{Binding TotalRows}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,16,0">
                <TextBlock Text="Cycle" Style="{StaticResource CaptionTextStyle}" Margin="0,0,6,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding CycleCount}" FontWeight="SemiBold" />
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,16,0">
                <TextBlock Text="Elapsed" Style="{StaticResource CaptionTextStyle}" Margin="0,0,6,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ElapsedTime}" FontWeight="SemiBold" />
            </StackPanel>

            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Border Margin="0,0,8,0"
                        Padding="8,3"
                        Background="{StaticResource Brush.Warning}"
                        CornerRadius="8"
                        Visibility="{Binding CurrentSnapshot.ProtError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Protection Error" Foreground="White" FontWeight="SemiBold" />
                </Border>
                <Border Padding="8,3"
                        Background="{StaticResource Brush.AccentStrong}"
                        CornerRadius="8"
                        Visibility="{Binding CurrentSnapshot.PowerGood, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Power Good" Foreground="White" FontWeight="SemiBold" />
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
